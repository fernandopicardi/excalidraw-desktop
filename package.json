{
  "name": "excalidraw-desktop",
  "version": "1.0.0",
  "description": "Excalidraw Desktop App with Mermaid integration",
  "main": "electron/main.js",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "packages/*",
    "electron",
    "src"
  ],
  "scripts": {
    "dev": "yarn build && electron .",
    "dev:hot": "concurrently \"yarn workspace @excalidraw/desktop-renderer dev\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "yarn workspace @excalidraw/desktop-renderer build",
    "build:electron": "yarn build && electron-builder",
    "pack:portable": "yarn build && electron-packager . --platform=win32 --arch=x64 --out=dist/portable --overwrite",
    "dist": "yarn build && electron-builder --publish=never",
    "start": "electron .",
    "test": "yarn workspace @excalidraw/desktop-renderer test",
    "lint": "yarn workspace @excalidraw/desktop-renderer lint",
    "clean": "rimraf dist build node_modules packages/*/node_modules electron/node_modules"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "electron-packager": "^17.0.0",
    "rimraf": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "author": "fernandopicardi <fernandopicardi@gmail.com>",
  "license": "MIT",
  "build": {
    "appId": "com.excalidraw.desktop",
    "productName": "Excalidraw Desktop",
    "directories": {
      "output": "dist"
    },
    "icon": "assets/icon.ico",
    "files": [
      "build/**/*",
      "electron/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "!node_modules/**/test/**/*",
      "!node_modules/**/tests/**/*"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "engines": {
    "node": "18.0.0 - 22.x.x"
  }
}
